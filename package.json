{
  "name": "sleep-aid",
  "version": "1.0.0",
  "private": true,
  "description": "Sleep Aid - Cognitive Shuffling with DashScope CosyVoice TTS",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd frontend && pnpm dev",
    "dev:backend": "cd backend && node --watch server.js",
    "build": "cd frontend && pnpm build",
    "build:prod": "cd frontend && pnpm build:prod",
    "start": "cd backend && node server.js",
    "install:all": "cd frontend && pnpm install --prefer-offline && cd ../backend && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
